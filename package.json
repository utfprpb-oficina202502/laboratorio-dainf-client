{
  "name": "tcc-client",
  "engines": {
    "node": ">=20.x",
    "npm": ">=10.x"
  },
  "version": "0.1.2",
  "scripts": {
    "ng": "ng",
    "build": "ng build --configuration production",
    "dev": "ng serve",
    "lint": "ng lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "start": "node server.js",
    "heroku-postbuild": "node set-env.js && npm run build",
    "pwa:generate-icons": "node generate-pwa-icons.js",
    "pwa:convert-icons": "node convert-icons-to-png.js",
    "pwa:test": "npm run build && cd dist/tcc-client/browser && http-server -p 8080 -c-1",
    "pwa:test:windows": "test-pwa-local.bat",
    "pwa:test:unix": "bash test-pwa-local.sh"
  },
  "private": true,
  "dependencies": {
    "@amcharts/amcharts5": "^5.14.2",
    "@angular/animations": "^20.3.2",
    "@angular/cdk": "^20.2.5",
    "@angular/common": "^20.3.2",
    "@angular/compiler": "^20.3.2",
    "@angular/core": "^20.3.2",
    "@angular/forms": "^20.3.2",
    "@angular/platform-browser": "^20.3.2",
    "@angular/platform-browser-dynamic": "^20.3.2",
    "@angular/router": "^20.3.2",
    "@angular/service-worker": "^20.3.3",
    "@eslint/js": "^9.37.0",
    "@fullcalendar/core": "^6.1.19",
    "@primeuix/themes": "^1.2.3",
    "@tailwindcss/postcss": "^4.1.13",
    "compression": "^1.8.1",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "ng2-currency-mask": "^13.0.3",
    "primeicons": "^7.0.0",
    "primeng": "^20.0.1",
    "quill": "^2.0.3",
    "rxjs": "^7.8.1",
    "sweetalert2": "^11.23.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.4",
    "@angular/cli": "^20.3.4",
    "@angular/compiler-cli": "^20.3.2",
    "@testing-library/angular": "^18.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^26.0.24",
    "@types/node": "^24.6.2",
    "angular-eslint": "20.3.0",
    "autoprefixer": "^10.4.21",
    "dotenv-webpack": "^8.1.0",
    "eslint": "^9.35.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-preset-angular": "^9.0.7",
    "postcss": "^8.5.6",
    "postcss-nesting": "^13.0.2",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.4",
    "typescript": "~5.9.0",
    "typescript-eslint": "8.40.0"
  }
}
